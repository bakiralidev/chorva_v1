# App configuration
PROJECT_NAME="Livestock Trading Platform MVP"
SECRET_KEY="super-secret-key-change-me-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
# Default to SQLite if not specified. For PostgreSQL, uncomment below and set values.
DATABASE_URL="sqlite+aiosqlite:///./chorva.db"

# PostgreSQL configurations (Uncomment and set if using Docker/Postgres)
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/chorva"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chorva
POSTGRES_PORT=5432
