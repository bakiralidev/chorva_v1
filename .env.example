# App configuration
PROJECT_NAME="Livestock Trading Platform MVP"
SECRET_KEY="super-secret-key-change-me-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
DATABASE_URL="sqlite:///./test.db"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-bot-token-from-botfather"

# Gmail SMTP (App Password orqali)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="your-email@gmail.com"
SMTP_PASSWORD="your-gmail-app-password"
SMTP_FROM_NAME="Chorva.uz"

# Google OAuth2 (Google Cloud Console dan olinadi)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/front/auth/google/callback"
